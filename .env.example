# Database
POSTGRES_URL=postgresql://user:pass@localhost:5432/looply

# AI & LLM Engine
AI_GATEWAY_API_KEY=
AI_CHAT_MODEL=openai/gpt-4o-mini
AI_CHAT_MAX_STEPS=10
AI_SUMMARY_MODEL=openai/gpt-4o-mini

# Email Provider (ses | sendgrid | resend)
EMAIL_PROVIDER=ses
EMAIL_FROM=hello@looply.ai
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# SENDGRID_API_KEY=

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=

# Auth
AUTH_SECRET=change-this-to-a-random-32-char-string-min
JWT_EXPIRY=1d

# Rate Limiting (Upstash)
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=example-token

# App
APP_URL=http://localhost:3000
NODE_ENV=development
CRON_SECRET=this-is-a-random-16-char-string-for-cron-auth

AI_CHAT_MODEL="openai/gpt-4o-mini"
AI_CHAT_MAX_STEPS=4
AI_SUMMARY_MODEL=gpt-4.1-nano
AI_EMBEDDING_MODEL=openai/text-embedding-3-small