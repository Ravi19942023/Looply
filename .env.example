# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

APP_URL=http://localhost:3000
NODE_ENV=development

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****
UPSTASH_REDIS_REST_URL=****
UPSTASH_REDIS_REST_TOKEN=****

# email delivery
EMAIL_PROVIDER=ses
EMAIL_FROM=hello@looply.ai
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=****
AWS_SECRET_ACCESS_KEY=****

# background jobs
CRON_SECRET=****

# chat limits
CHAT_MAX_MESSAGES_PER_HOUR=1000
CHAT_HISTORY_LIMIT=30



# ai engine settings (default: moonshotai/kimi-k2-0905)
# Options: openai/gpt-oss-120b, moonshotai/kimi-k2.5, mistral/codestral, etc.
AI_CHAT_MODEL=moonshotai/kimi-k2-0905
AI_CHAT_MAX_STEPS=4
AI_SUMMARY_MODEL=gpt-4.1-nano
AI_EMBEDDING_MODEL=openai/text-embedding-3-small
