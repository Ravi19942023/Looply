{
  "name": "looply",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:adapter-integration": "cross-env RUN_DB_ADAPTER_TESTS=true vitest run src/backend/adapters/vector/pgvector.adapter.test.ts",
    "test:integration": "cross-env RUN_DB_REPOSITORY_TESTS=true vitest run src/backend/modules/repositories.test.ts",
    "test:watch": "vitest",
    "analyze": "cross-env ANALYZE=true next build",
    "db:generate": "drizzle-kit generate",
    "db:ensure-pgvector": "tsx src/backend/db/ensure-pgvector.ts",
    "db:migrate:deploy": "tsx src/backend/db/migrate.ts",
    "db:push": "npm run db:ensure-pgvector && drizzle-kit push",
    "db:seed": "npm run db:ensure-pgvector && tsx src/backend/db/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.143",
    "@aws-sdk/client-sesv2": "^3.1019.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@neondatabase/serverless": "^1.0.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/prosemirror-tables": "^0.8.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.35.6",
    "@vercel/blob": "^2.3.2",
    "ai": "^6.0.141",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "date-fns": "^4.1.0",
    "diff-match-patch": "^1.0.5",
    "drizzle-orm": "^0.44.5",
    "fast-deep-equal": "^3.1.3",
    "framer-motion": "^12.38.0",
    "jose": "^6.1.0",
    "katex": "^0.16.44",
    "llamaindex": "^0.12.1",
    "lucide-react": "^0.542.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.1",
    "pino": "^9.9.2",
    "prosemirror-example-setup": "^1.2.3",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-view": "^1.41.8",
    "react": "19.2.4",
    "react-data-grid": "^7.0.0-beta.59",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.2.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "use-stick-to-bottom": "^1.1.3",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.1.11",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
